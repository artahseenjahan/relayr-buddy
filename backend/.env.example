# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
# Database: if direct db.*.supabase.co fails (IPv6-only), use Session pooler from Dashboard → Connect → Session pooler.
# Use async driver prefix. URL-encode special characters in the password (e.g. [ ] → %5B %5D).
# SUPABASE_DB_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
SUPABASE_DB_SSL_VERIFY=true

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
APP_ENCRYPTION_KEY=your-generated-fernet-key

# OpenRouter LLM
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# App
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=false
